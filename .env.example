# =============================================================================
# AppStore Infrastructure — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values.
# .env is NOT committed to Git.
#
# Generate ENCRYPTION_KEY with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# -----------------------------------------------------------------------------
# Server IP (Floating IP of the OpenStack VM)
# -----------------------------------------------------------------------------
SERVER_IP=141.72.176.200

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=change_me_secure_password
DB_NAME=dozilab
DB_PORT=5432

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-generated-fernet-key-here

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_secure_password

# These values must match the imported realm (keycloak/realm-export.json)
KEYCLOAK_REALM=Dozilab
KEYCLOAK_CLIENT_ID_BACKEND=appstore-backend
KEYCLOAK_CLIENT_ID_FRONTEND=appstore-frontend
KEYCLOAK_JWKS_CACHE_TTL=3600

# Keycloak runs behind nginx on port 8443
KEYCLOAK_URL=https://${SERVER_IP}:8443

# -----------------------------------------------------------------------------
# Ansible SSH Key
# -----------------------------------------------------------------------------
# Path to the private SSH key on the host (mounted as a volume)
# Generate once: ssh-keygen -t ed25519 -f ~/.ssh/dozilab_ansible -N ""
ANSIBLE_SSH_KEY_PATH=~/.ssh/dozilab_ansible
ANSIBLE_SSH_KEY_NAME=dozilab-ansible-key

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_secure_password

# -----------------------------------------------------------------------------
# Docker Images (set by CI/CD)
# -----------------------------------------------------------------------------
# Staging uses :staging tag, Production uses :latest
BACKEND_IMAGE=ghcr.io/dozilab/appstore-backend:latest
FRONTEND_IMAGE=ghcr.io/dozilab/appstore-frontend:staging
