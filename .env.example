# =============================================================================
# AppStore Infrastructure — Environment Variables
# =============================================================================
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# .env wird NICHT ins Git eingecheckt.
#
# Generiere ENCRYPTION_KEY mit:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# -----------------------------------------------------------------------------
# Server IP (Floating IP der OpenStack VM)
# -----------------------------------------------------------------------------
SERVER_IP=141.72.176.200

# -----------------------------------------------------------------------------
# Datenbank
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=change_me_secure_password
DB_NAME=dozilab
DB_PORT=5432

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-generated-fernet-key-here

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_secure_password

# Diese Werte müssen mit dem importierten Realm übereinstimmen (keycloak/realm-export.json)
KEYCLOAK_REALM=Dozilab
KEYCLOAK_CLIENT_ID_BACKEND=appstore-backend
KEYCLOAK_CLIENT_ID_FRONTEND=appstore-frontend
KEYCLOAK_JWKS_CACHE_TTL=3600

# Keycloak läuft auf Port 8443 mit self-signed Zertifikat
KEYCLOAK_URL=https://${SERVER_IP}:8443

# -----------------------------------------------------------------------------
# Ansible SSH Key
# -----------------------------------------------------------------------------
# Pfad zum privaten SSH-Key auf dem Host (wird als Volume gemountet)
# Einmalig generieren: ssh-keygen -t ed25519 -f ~/.ssh/dozilab_ansible -N ""
ANSIBLE_SSH_KEY_PATH=~/.ssh/dozilab_ansible
ANSIBLE_SSH_KEY_NAME=dozilab-ansible-key

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_secure_password

# -----------------------------------------------------------------------------
# Docker Images (werden von CI/CD gesetzt)
# -----------------------------------------------------------------------------
BACKEND_IMAGE=ghcr.io/your-org/appstore-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/appstore-frontend:latest
